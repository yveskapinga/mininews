<!DOCTYPE html>
{#
    data-turbo="false" desactive la navigation Turbo/Symfony UX sur l'ensemble
    du site. Sans cela, les clics sur les liens du menu sont interceptes par
    Turbo, ce qui peut provoquer des pages blanches apres navigation si les
    ecouteurs JavaScript (Bootstrap, animations, etc.) ne sont pas reinitialises
    correctement. On garde ainsi une navigation classique et fiable.
#}
<html lang="fr" data-turbo="false">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        {# Favicon SVG personnalise affiche dans l'onglet du navigateur. #}
        <link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">
        <title>{% block title %}MiniNews{% endblock %}</title>

        {#
            Template racine de l'application.

            Les autres fichiers Twig commencent par {% extends 'base.html.twig' %}:
            ils heritent donc de cette structure HTML commune et remplissent les
            blocs title/body. Cela evite de repeter le <head>, la navigation et
            l'affichage des messages flash sur chaque page.
        #}

        {#
            importmap('app') charge l'entree JavaScript declaree dans importmap.php.
            assets/app.js importe ensuite Bootstrap (CSS + JS), notre CSS
            supplementaire et initialise le comportement JS (flash, animations).
        #}
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {#
            Securite d'affichage: si JavaScript est desactive, les elements
            data-animate="fade-up" resteraient invisibles. Ce fallback les rend
            visibles immediatement pour que le contenu soit toujours accessible.
        #}
        <noscript>
            <style>
                [data-animate="fade-up"] {
                    opacity: 1 !important;
                    transform: none !important;
                }
            </style>
        </noscript>
    </head>
    <body>
        {# Barre de navigation Bootstrap responsive.
           Le composant navbar-collapse masque les liens sur petit ecran et les
           affiche derriere un bouton "hamburger". #}
        <header>
            <nav class="navbar navbar-expand-lg mn-navbar" aria-label="Navigation principale">
                <div class="container">
                    {# path('news_index') genere l'URL de la route nommee news_index. #}
                    <a class="navbar-brand" href="{{ path('news_index') }}">
                        <img src="{{ asset('logo.svg') }}" alt="" width="34" height="34">
                        MiniNews
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Ouvrir le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-auto align-items-lg-center">
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('news_index') }}">Actualités</a>
                            </li>

                            {#
                                is_granted interroge Symfony Security. Le lien admin n'est
                                affiche que si l'utilisateur courant possede ROLE_ADMIN.
                            #}
                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('admin_article_index') }}">Articles admin</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('admin_user_index') }}">Utilisateurs</a>
                                </li>
                            {% endif %}

                            {#
                                app.user contient l'utilisateur connecte, ou null si le
                                visiteur est anonyme. Twig accede aux getters PHP avec une
                                syntaxe courte: app.user.displayName appelle getDisplayName().
                            #}
                            {% if app.user %}
                                <li class="nav-item">
                                    <span class="mn-nav-user">Bonjour {{ app.user.displayName }}</span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
                                </li>
                            {% else %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_register') }}">Inscription</a>
                                </li>
                            {% endif %}
                        </ul>
                    </div>
                </div>
            </nav>
        </header>

        <main class="mn-page-container">
            {#
                Les messages flash sont ajoutes dans les controleurs avec
                addFlash(). Ils survivent a une redirection, puis sont consommes
                ici par app.flashes. La classe .mn-flash est enrichie par
                assets/app.js pour disparaitre automatiquement apres 5 secondes.
            #}
            <div aria-live="polite" aria-atomic="true">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mn-flash mn-flash-{{ label }}">{{ message }}</div>
                    {% endfor %}
                {% endfor %}
            </div>

            {# Les pages enfants remplacent ce bloc par leur contenu principal. #}
            {% block body %}{% endblock %}
        </main>
    </body>
</html>
